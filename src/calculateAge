#include <stdio.h>

int main(){
  int currYr;
  int birthYr;
  int age;
  //simpler: int currYr, birthYr, age//
  printf("Please type the current year: ");
  scanf("%d", &currYr);
  printf("Please type your birth year: ");
  scanf("%d", &birthYr);
  age = currYr - birthYr;
  printf("You are %d years old", age);
  
  return 0;
}

